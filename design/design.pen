                    },
                    {
                      "type": "text",
                      "id": "e1l2u",
                      "name": "bio",
                      "fill": "#0d1014",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "На протяжении многих лет практикует китайские боевые искусства, в том числе тайцзицюань стиля Ян",
                      "lineHeight": 1.3,
                      "fontFamily": "Manrope",
                      "fontSize": 15,
                      "fontWeight": "600",
                      "letterSpacing": -0.16
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "sWNpi",
