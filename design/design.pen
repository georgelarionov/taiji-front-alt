                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Губернатор Ивановской области",
                      "fontFamily": "Manrope",
                      "fontSize": 15,
                      "fontWeight": "600",
                      "letterSpacing": -0.16
                    },
                    {
                      "type": "rectangle",
                      "id": "l24eqV",
                      "name": "div",
