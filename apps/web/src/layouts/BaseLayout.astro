---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
// import Loader from "../components/Loader.astro"; // ЛОУДЕР ВРЕМЕННО ОТКЛЮЧЁН — раскомментировать для возврата
import Menu from "../components/Menu.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = "Общество изучения традиционного тайцзицюань",
  description = "Информационный портал Общества изучения традиционного тайцзицюань: исследования, сохранение и развитие традиции в России.",
  ogImage,
  noindex,
} = Astro.props;

// Канонический URL текущей страницы на домене из astro.config (site).
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {/* Канонический URL — абсолютный, на домене из site (astro.config). */}
    <link rel="canonical" href={canonicalURL} />
    {/* Open Graph — превью при шеринге; locale ru_RU. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Общество изучения традиционного тайцзицюань" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}
    {/* Twitter card. */}
    <meta name="twitter:card" content="summary_large_image" />
    {/* Запрет индексации (для служебных страниц вроде 404). */}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {/* Шрифты (Astro Fonts API): @font-face + метрически подогнанные fallback'и.
        Без preload — иначе тянулись бы все веса/курсивы; FOUT гасится оптимизированными fallback'ами. */}
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-cormorant" />
    <Font cssVariable="--font-manrope" />
    {/* JS доступен — помечаем до первой отрисовки (для reveal без мигания).
        Здесь же решаем показ лоудера: класс loading ставится ДО пейнта и только
        при первом заходе за сессию без reduced-motion → нет флэша и повторов. */}
    <script is:inline>
      document.documentElement.classList.add("js");
      // ЛОУДЕР ВРЕМЕННО ОТКЛЮЧЁН (на время правок). Вернуть: раскомментировать блок ниже
      // + <Loader /> и import "../lib/loader" в <body>. Без html.loading hero раскрывается сразу.
      // try {
      //   if (
      //     // TEST: гейт «один раз за сессию» временно отключён — лоудер на каждой загрузке.
      //     // Вернуть: раскомментировать строку ниже.
      //     // !sessionStorage.getItem("taiji:loaded") &&
      //     !window.matchMedia("(prefers-reduced-motion: reduce)").matches
      //   ) {
      //     document.documentElement.classList.add("loading");
      //   }
      // } catch {}
    </script>
    {/* Пер-страничные мета/preload (на будущее): <Fragment slot="head">…</Fragment>. */}
    <slot name="head" />
    <ClientRouter />
  </head>
  <body class="min-h-dvh bg-white font-sans text-ink antialiased">
    {/* ЛОУДЕР ВРЕМЕННО ОТКЛЮЧЁН (на время правок) — раскомментировать для возврата */}
    {/* <Loader /> */}
    {/* Skip-link: первый фокусируемый элемент — прыжок на <main> для клавиатуры/скринридеров.
        sr-only до фокуса, видимый при focus. */}
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:left-4 focus:top-4 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:text-ink"
      >К основному содержимому</a
    >
    <Menu />
    {/* <main> — обычный блок БЕЗ overflow: Hero (sticky) и контент ниже остаются
        сиблингами внутри него, поэтому hero-parallax (sticky) сохраняется. */}
    <main id="main">
      <slot />
    </main>

    {/* Agentation — визуальные аннотации для AI-агента, ТОЛЬКО в dev.
        Динамический импорт под import.meta.env.DEV → Vite вырезает ветку и сам пакет
        из прод-сборки целиком (никаких orphan-чанков в dist). */}
    <script>
      // Тулбар включён в dev. Закомментируй, чтобы скрыть аннотации.
      if (import.meta.env.DEV) import("../lib/agentation-dev");
    </script>

    {/* Рантайм лоудера: init/teardown на astro:page-load / astro:before-swap (как smooth) */}
    {/* ЛОУДЕР ВРЕМЕННО ОТКЛЮЧЁН (на время правок) — раскомментировать для возврата */}
    {/* <script>
      import "../lib/loader";
    </script> */}

    {/* Анимационный рантайм: Lenis + GSAP, пере-инициализация на навигации */}
    <script>
      import "../lib/smooth";
    </script>

    {/* Рантайм меню: открытие/закрытие, Esc, блок скролла, фокус (как loader/smooth) */}
    <script>
      import "../lib/menu";
    </script>
  </body>
</html>
