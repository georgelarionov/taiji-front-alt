---
// Страница отдельной новости (/news/<slug>). Статически генерируется по датасету
// data/news (getStaticPaths). Шелл как у остальных внутренних страниц: solid-шапка
// (активный пункт «Новости»), крошки отдельным блоком, сквозной глобальный футер —
// чтобы страница не выглядела инородной. Контент в центральной колонке чтения 809px:
// дата → заголовок → мета+шеринг → главное изображение → rich-text → автор. Ниже —
// full-bleed слайдер «Другие новости». Тело статьи пока общий плейсхолдер (CMS позже).
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import ArticleIntro from "../../components/news/ArticleIntro.astro";
import ArticleBody from "../../components/news/ArticleBody.astro";
import ArticleAuthor from "../../components/news/ArticleAuthor.astro";
import RelatedNews from "../../components/news/RelatedNews.astro";
import {
  articles,
  relatedArticles,
  SOCIETY_AUTHOR,
  type NewsArticle,
} from "../../data/news";
import { articleSchema, ruDateToISO } from "../../lib/seo";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: NewsArticle;
}
const { article } = Astro.props;
const related = relatedArticles(article.slug, 6);

// NewsArticle: заголовок, лид, главное фото (абс. URL), дата публикации (ISO).
// headline ограничен рекомендацией Google ≤110 симв.: у длинных заголовков
// (>110) берём shortTitle (он же — текст хлебной крошки), иначе полный title.
const headline =
  article.title.length > 110 ? article.shortTitle : article.title;
const schema = articleSchema(
  {
    site: Astro.site,
    path: Astro.url.pathname,
    name: headline,
    description: article.excerpt,
    image: article.image?.src,
  },
  { type: "NewsArticle", datePublished: ruDateToISO(article.date), section: "Новости" },
);
---

<BaseLayout
  title={`${article.title} — Общество изучения традиционного тайцзицюань`}
  description={article.excerpt}
  schema={schema}
>
  <Header variant="solid" activeNav="Новости" />
  <Breadcrumbs
    items={[
      { label: "Главная", href: "/" },
      { label: "Новости", href: "/news" },
      { label: article.shortTitle },
    ]}
  />

  <article class="bg-white pt-14 pb-20 max-lg:pt-8 max-lg:pb-12">
    <div class="container-block">
      <div class="mx-auto w-full max-w-[809px]">
        <ArticleIntro
          date={article.date}
          title={article.title}
          readingTime={article.readingTime}
        />

        {/* Главное изображение статьи: 16:9, fit (object-contain) на подложке
            цвета шапки — как обложки в карточках ленты. Нет фото — не рендерим
            (у видео-статьи ведущим визуалом станет ролик в теле). */}
        {
          article.image && (
            <div class="mt-10 aspect-video w-full bg-surface p-2 max-lg:mt-6 max-lg:p-1">
              <Image
                src={article.image}
                alt={article.imageAlt ?? article.title}
                widths={[400, 809, 1218]}
                sizes="(max-width: 1024px) 100vw, 809px"
                class="h-full w-full object-contain"
              />
            </div>
          )
        }

        <div class="mt-12 max-lg:mt-8">
          <ArticleBody body={article.body} />
        </div>

        <ArticleAuthor author={article.author ?? SOCIETY_AUTHOR} />
      </div>
    </div>
  </article>

  <RelatedNews cards={related} />
  <Footer />
</BaseLayout>
