---
// Страница «Практика» (/taijiquan/practice). Внутренний раздел на эталоне
// /taijiquan/history: solid-Header (активный «Тайцзицюань»), крошки до текущего
// раздела, общий InteriorHero, сквозной Footer. Контент — editorial-лонгрид
// PracticeArticle (заменил общую заглушку ContentPlaceholder). В «Узнайте больше»
// карточка «Практика» приглушена как текущая (current).
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import InteriorHero from "../../components/InteriorHero.astro";
import PracticeArticle from "../../components/taiji/PracticeArticle.astro";
import TaijiExplore from "../../components/taiji/TaijiExplore.astro";
import Footer from "../../components/Footer.astro";
import { articleSchema } from "../../lib/seo";

const description =
  "Практика тайцзицюань: форма и таолу, работа с телом и равновесием, дыхание, туйшоу, роль преподавателя, безопасность и адаптация.";
const schema = articleSchema(
  {
    site: Astro.site,
    path: Astro.url.pathname,
    name: "Практика тайцзицюань",
    description,
  },
  { section: "Тайцзицюань" },
);
---

<BaseLayout
  title="Практика — Общество изучения традиционного тайцзицюань"
  description={description}
  schema={schema}
>
  <Header variant="solid" activeNav="Тайцзицюань" />
  <Breadcrumbs
    items={[
      { label: "Главная", href: "/" },
      { label: "Тайцзицюань", href: "/taijiquan" },
      { label: "Практика" },
    ]}
  />
  <InteriorHero
    title="Практика"
    subtitle="Форма, внимание, дыхание и работа с телом"
  />
  <PracticeArticle />
  <TaijiExplore current="Практика" />
  <Footer />
</BaseLayout>
