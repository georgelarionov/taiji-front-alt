---
// Страница «Персоналии» (/taijiquan/person). Дубль внутреннего раздела на эталоне
// /taijiquan/history: solid-Header (активный «Тайцзицюань»), крошки до текущего
// раздела, общий InteriorHero + контент-заглушка, сквозной Footer. В «Узнайте
// больше» карточка «Персоналии» приглушена как текущая (current). Контент — заглушка.
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import InteriorHero from "../../components/InteriorHero.astro";
import ContentPlaceholder from "../../components/ContentPlaceholder.astro";
import TaijiExplore from "../../components/taiji/TaijiExplore.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout
  title="Персоналии — Общество изучения традиционного тайцзицюань"
  description="Персоналии тайцзицюань: мастера и семейные линии, сохранившие и передавшие традицию."
>
  <Header variant="solid" activeNav="Тайцзицюань" />
  <Breadcrumbs
    items={[
      { label: "Главная", href: "/" },
      { label: "Тайцзицюань", href: "/taijiquan" },
      { label: "Персоналии" },
    ]}
  />
  <InteriorHero
    title="Персоналии"
    subtitle="Мастера и семейные линии, сохранившие традицию тайцзицюань"
  />
  <ContentPlaceholder />
  <TaijiExplore current="Персоналии" />
  <Footer />
</BaseLayout>
