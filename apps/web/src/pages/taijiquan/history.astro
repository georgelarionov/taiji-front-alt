---
// Страница «История» (/taijiquan/history). Собрана по фреймам MagicPath
// Template-1 / Mobile-Template-1 на эталоне /taijiquan: solid-Header (активный пункт
// «Тайцзицюань»), крошки Главная → Тайцзицюань → История, сквозной Footer.
// Hero — общий компонент внутренних разделов (InteriorHero). Контент раздела —
// editorial-лонгрид HistoryArticle (заменил общую заглушку ContentPlaceholder).
// В «Узнайте больше» текущий раздел приглушён (current).
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import InteriorHero from "../../components/InteriorHero.astro";
import HistoryArticle from "../../components/taiji/HistoryArticle.astro";
import TaijiExplore from "../../components/taiji/TaijiExplore.astro";
import Footer from "../../components/Footer.astro";
import { articleSchema } from "../../lib/seo";

const description =
  "История тайцзицюань: от семейной боевой традиции в Китае до мировой практики движения.";
const schema = articleSchema(
  {
    site: Astro.site,
    path: Astro.url.pathname,
    name: "История тайцзицюань",
    description,
  },
  { section: "Тайцзицюань" },
);
---

<BaseLayout
  title="История — Общество изучения традиционного тайцзицюань"
  description={description}
  schema={schema}
>
  <Header variant="solid" activeNav="Тайцзицюань" />
  <Breadcrumbs
    items={[
      { label: "Главная", href: "/" },
      { label: "Тайцзицюань", href: "/taijiquan" },
      { label: "История" },
    ]}
  />
  <InteriorHero
    title="История"
    subtitle="От семейной боевой традиции в Китае до мировой практики движения"
  />
  <HistoryArticle />
  <TaijiExplore current="История" />
  <Footer />
</BaseLayout>
