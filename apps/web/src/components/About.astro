---
// 2-block — «О тайцзицюань». Собрано из design/design.pen, фрейм «2-block».
// Обычный контейнер (не full-bleed): max-w-1440 + px-11 (44px) → контент 1352 на ≥1440.
// Хедер (заголовок + плашка-кнопка с каллиграфией) и сетка 2×2 карточек-разделов.
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import headerLogo from "../assets/block2/calif-symbols.png";
import historyImg from "../assets/block2/history-card.png";
import AboutInfo from "./AboutInfo.tsx";

// Класс «Подробнее» — как в блоке «Новости»: анимированное подчёркивание (от левого
// края), проявляется на hover всей карточки (group-hover). w-fit — линия по ширине
// текста; relative z-10 — над hover-подложкой.
const moreClass =
  "relative z-10 w-fit font-display text-base font-semibold leading-[1.1] text-accent after:absolute after:inset-x-0 after:bottom-0 after:h-0.5 after:origin-left after:scale-x-0 after:bg-accent/50 after:transition-transform after:duration-300 group-hover:after:scale-x-100";

// Иконка info (ⓘ) кнопки «ПОДРОБНЕЕ» — точная геометрия из ноды (viewBox 0 0 20 20).
const infoIcon =
  "M10 20c-5.52285 0-10-4.4772-10-10 0-5.52285 4.47715-10 10-10 5.5228 0 10 4.47715 10 10 0 5.5228-4.4772 10-10 10z m0-2c4.4183 0 8-3.5817 8-8 0-4.41828-3.5817-8-8-8-4.41828 0-8 3.58172-8 8 0 4.4183 3.58172 8 8 8z m-1-13l2 0 0 2-2 0 0-2z m0 4l2 0 0 6-2 0 0-6z";

// Текст контекстного окна-справки (Inter 15px). Ударения/тоны сохранены как есть.
const infoText =
  "Тайцзицюа́нь (тай-чи) (кит. трад. 太極拳, упр. 太极拳, пиньинь tàijíquán, палл. Тайцзицюань, буквально: «кулак Великого (Изначального) Предела») — китайское внутреннее боевое искусство, один из видов ушу (происхождение тайцзицюань — исторически спорный вопрос, разные источники имеют разные версии).";

const cards: { title: string; desc: string; image?: ImageMetadata }[] = [
  {
    title: "История",
    desc: "Происхождения и развития тайцзицюань как традиции, школы мысли и практики.",
    image: historyImg,
  },
  {
    title: "Теория",
    desc: "Основные понятия, принципы движения и идеи, на которых строится тайцзицюань.",
  },
  {
    title: "Практика",
    desc: "Формы, упражнения и методы, через которые традиция передаётся и сохраняется.",
  },
  {
    title: "Персоналии",
    desc: "Мастера, исследователи и носители традиции, повлиявшие на тайцзицюань.",
  },
];
---

<section class="bg-white pt-16 pb-24 max-lg:py-16">
  <div class="mx-auto w-full max-w-[1440px] px-11 max-lg:px-4">
    <div class="flex flex-col gap-[46px] max-lg:gap-8">
      {/* ───────── Хедер ───────── */}
      <header
        data-reveal
        class="relative z-40 flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between lg:gap-12 max-lg:gap-6"
      >
        <div class="flex max-w-[454px] flex-col gap-[18px] max-lg:max-w-none max-lg:gap-6">
          <h2 class="font-display text-[40px] font-semibold leading-[1.1] text-ink max-lg:text-[30px]">
            О тайцзицюань
          </h2>
          <p class="font-sans text-base font-medium text-ink/65 max-lg:text-[15px]">
            Многовековая школа мысли, практики и наставничества
          </p>
        </div>

        {/* Плашка-кнопка: каллиграфия + «ПОДРОБНЕЕ ⓘ» → контекстное окно-справка */}
        <AboutInfo
          client:load
          logoSrc={headerLogo.src}
          logoWidth={headerLogo.width}
          logoHeight={headerLogo.height}
          logoAlt="太極拳 — тайцзицюань"
          infoIcon={infoIcon}
          text={infoText}
        />
      </header>

      {/* ───────── Сетка разделов 2×2 / 1-col mobile ─────────
          Карточка целиком — <a> (как в «Новостях»): курсор pointer, hover-подложка
          #f7f5f4 (inset-2), «Подробнее» подчёркивается через group-hover.
          У «Истории» дополнительно на hover справа проявляется изображение.
          На мобиле — одна колонка (lg:grid-cols-2 вместо md:grid-cols-2). */}
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 max-lg:gap-6">
        {
          cards.map((card) => (
            <a
              href="#"
              data-reveal
              class="group relative flex min-h-[263px] cursor-pointer flex-col justify-between overflow-hidden border border-black/15 p-7 max-lg:min-h-0 max-lg:justify-start max-lg:gap-12 max-lg:p-6"
            >
              {/* hover-подложка */}
              <div class="pointer-events-none absolute inset-2 bg-[#f7f5f4] opacity-0 transition-opacity duration-300 group-hover:opacity-100" />

              {/* hover-изображение справа (только «История») */}
              {card.image && (
                <div class="pointer-events-none absolute inset-y-7 right-7 z-[5] flex items-center opacity-0 transition-opacity duration-700 ease-out group-hover:opacity-100 max-lg:hidden">
                  <Image
                    src={card.image}
                    alt=""
                    widths={[280, 560]}
                    sizes="280px"
                    class="h-full w-auto object-contain"
                  />
                </div>
              )}

              <div class="relative z-10 flex max-w-[336px] flex-col gap-4 max-lg:max-w-none max-lg:gap-3">
                <h3 class="font-display text-[26px] font-semibold leading-[1.1] text-ink max-lg:text-[21px]">
                  {card.title}
                </h3>
                <p class="font-sans text-[15px] font-medium leading-normal text-ink/70 max-lg:text-[15px] max-lg:leading-[1.4]">
                  {card.desc}
                </p>
              </div>
              <span class={moreClass}>Подробнее</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
