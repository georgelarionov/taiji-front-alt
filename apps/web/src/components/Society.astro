---
// 5-block — «Об Обществе». Из design/design.pen, фрейм «5-block».
// Двухколоночная карточка: слева surface-панель (заголовок, описание, каллиграфия,
// кнопки-ссылки «Миссия и ценности»/«Команда»), справа — белый слайдер персон
// (React-остров, стрелки/точки меняют контент; пока контент продублирован).
import { getImage } from "astro:assets";
import SocietySlider, { type SocietySlide } from "./SocietySlider.tsx";
// Фото персоны в слайде — это <Image> нельзя рендерить внутри React-острова,
// поэтому оптимизируем здесь через getImage() и передаём готовый src в слайдер.
import personSrc from "../assets/society/person-1.png";
import person2Src from "../assets/society/person-2.webp";
// Каллиграфия «传统太极拳学会» — вертикальный свиток, плоский брендовый раст:
// plain <img src={import.src}>, не <Image> (см. конвенции).
import caliSrc from "../assets/society/cali-vertical-5block.webp";
// Декоративный мазок над nav-кнопками (с альфой) — крупная полупрозрачная
// текстура → webp через getImage() (как фон в Research). Рендерится максимум
// на 534px → 1068w (2×) покрывает ретину.
import brushSrc from "../assets/society/bg-item-society.png";

// бокс фото 190×254 (как в PEN); 480w webp покрывает ретину и w-full на мобиле
const person = await getImage({ src: personSrc, width: 480, format: "webp" });
const person2 = await getImage({ src: person2Src, width: 480, format: "webp" });
const brushImg = await getImage({ src: brushSrc, width: 1068, format: "webp" });

const chair: SocietySlide = {
  role: "Председатель Общества",
  name: "Воскресенский Станислав Сергеевич",
  title: "Губернатор Ивановской области",
  bio: "На протяжении многих лет практикует китайские боевые искусства, в том числе тайцзицюань стиля Ян",
  photo: person.src,
  quote:
    "«Тайцзицюань — жемчужина китайской культуры, ставшая наследием всего человечества: сотни миллионов практикующих в более чем 180 странах, признание ЮНЕСКО, а с этого года — собственный международный день 21 марта. Наше общество объединяет тех, кто стремится постичь эту традицию глубоко и системно, в том числе и через обращение к её богатому литературному наследию. Сердечно приветствую всех, кто разделяет любовь к этому дивному искусству!»",
};

// второй слайд — председатель попечительского совета
const board: SocietySlide = {
  role: "Председатель попечительского совета",
  name: "Бабаев Кирилл Владимирович",
  title:
    "Директор Института Китая и современной Азии РАН, доктор филологических наук",
  bio: "Заместитель председателя Общества российско-китайской дружбы",
  photo: person2.src,
  quote:
    "«Сайт рыбатекст поможет дизайнеру, верстальщику, вебмастеру сгенерировать несколько абзацев более менее осмысленного текста рыбы на русском языке, а начинающему оратору отточить навык публичных выступлений в домашних условиях. При создании генератора мы использовали небезизвестный универсальный код речей. Текст генерируется абзацами случайным образом от двух до десяти предложений в абзаце, что позволяет...»",
};

const slides: SocietySlide[] = [chair, board];

// Ведут на секции страницы /society (якоря scroll-mt-24 в components/society/*) —
// та же раскладка, что в config/nav.ts navCols[1].links.
const tabs = [
  { label: "Миссия и ценности", href: "/society#mission" },
  { label: "Команда", href: "/society#team" },
  { label: "Документы", href: "/society#documents" },
  { label: "Партнёры", href: "/society#partners" },
];
---

{/* Моб: отступ от «Новостей» = 72px (8px этот pt + 64px нижний pb «Новостей»). */}
<section class="bg-white pt-24 pb-24 max-lg:pt-16 max-lg:pb-16">
  <div class="container-block">
    <div data-reveal class="grid grid-cols-1 lg:grid-cols-[692fr_660fr]">
      {/* ───────── Левая панель (surface) ───────── */}
      <div class="flex flex-col bg-surface p-12 max-lg:p-6 max-lg:pt-12">
        <div class="flex max-w-[557px] flex-col gap-6 max-lg:gap-4">
          <h2 class="font-display text-[32px] font-semibold leading-[1.1] text-ink max-lg:text-[26px]">
            Общество
          </h2>
          <p class="font-sans text-base font-medium leading-[1.375] text-ink/80 max-lg:text-[15px]">
            Общество изучения традиционного тайцзицюань — добровольное
            объединение мастеров, учёных, общественных и культурных деятелей. Мы
            исследуем традиционный тайцзицюань как социокультурное явление
            китайской цивилизации, поддерживаем диалог между школами и стилями и
            способствуем сохранению, развитию и распространению этой традиции в
            России.
          </p>
        </div>

        {/* Кнопки-ссылки (ведут на отдельные страницы).
            Сверху — каллиграфия поверх абсолютного декоративного мазка, затем
            первая линия без дополнительного gap. Hover: подчёркивание текста
            растёт слева направо (line @50%, origin-left). */}
        <nav class="mt-auto flex flex-col gap-6 pt-6 max-lg:mt-0 max-lg:gap-6 max-lg:pt-0">
          <div class="relative h-[208px] max-lg:h-[96px]">
            <img
              src={brushImg.src}
              alt=""
              aria-hidden="true"
              loading="lazy"
              decoding="async"
              class="pointer-events-none absolute bottom-0 left-0 z-0 h-[138px] w-[534px] max-w-full object-contain object-left select-none max-lg:h-[96px]"
            />
            <img
              src={caliSrc.src}
              width={caliSrc.width}
              height={caliSrc.height}
              alt="传统太极拳学会"
              lang="zh-Hans"
              class="absolute bottom-6 left-0 z-10 h-[200px] w-auto select-none max-lg:hidden"
            />
            <span class="absolute bottom-0 left-0 z-20 h-px w-full bg-border"></span>
          </div>
          {
            tabs.map((tab) => (
              <Fragment>
                <a
                  href={tab.href}
                  class="group font-display text-2xl font-semibold leading-none text-ink max-lg:text-xl"
                >
                  <span class="relative inline-block after:absolute after:inset-x-0 after:-bottom-1 after:h-px after:origin-left after:scale-x-0 after:bg-black/50 after:transition-transform after:duration-300 after:ease-smooth group-hover:after:scale-x-100">
                    {tab.label}
                  </span>
                </a>
                <span class="h-px w-full bg-border" />
              </Fragment>
            ))
          }
        </nav>
      </div>

      {/* ───────── Правая панель (слайдер) ─────────
          PEN (5-block): слайдер на 24px ниже surface-панели сверху и снизу (lg:my-6),
          бордер только сверху/справа/снизу — слева разделителем служит край surface. */}
      <div class="border border-border lg:my-6 lg:border-l-0">
        <SocietySlider client:load slides={slides} />
      </div>
    </div>
  </div>
</section>
