---
// Лонгрид «Практика тайцзицюань» (/taijiquan/practice). Заменяет общую заглушку
// ContentPlaceholder. Тот же editorial-паттерн, что и History/TheoryArticle:
// колонка чтения ~680px, выносные фигуры/цитаты, аппарат сносок (sup → #src-N),
// плейсхолдеры изображений bg-field с рекомендацией. Заголовок страницы (h1) — в
// InteriorHero, поэтому все разделы здесь — <h2>. Всё на токенах и тип-шкале;
// Cormorant (font-serif) — только editorial-акценты (буквица, врезные цитаты,
// названия элементов практики). Reveal — штатный data-reveal/-stagger.
//
// «Ключевые элементы практики» — лексикон (полоса surface-sunken). Сноски
// нумерованы 1:1 со списком «Источники» (1–5), как в исходном тексте.

import LongreadFigure from "./LongreadFigure.astro";
import SourcesList from "./SourcesList.astro";
import practiceOpener from "../../assets/taiji/longread/practice-opener.jpg";
import practiceForm from "../../assets/taiji/longread/practice-form.jpg";
import practiceTuishou from "../../assets/taiji/longread/practice-tuishou.jpg";
import practiceGroup from "../../assets/taiji/longread/practice-group.jpg";

// Ключевые элементы практики (рендерится лексиконом, а не таблицей).
const elements = [
  { name: "Форма", develops: "Координацию, память движения, равновесие, плавность." },
  { name: "Базовые шаги", develops: "Устойчивость, перенос веса, контроль направления." },
  { name: "Стойки", develops: "Опору, осанку, спокойное внимание." },
  { name: "Дыхание", develops: "Ритм, расслабление, снижение лишнего напряжения." },
  {
