      </dl>
    </div>
  </section>

  {/* ── Смысловые формулы (тёмная врезка) ── */}
  <section class="bg-ink py-24 max-lg:py-16">
    <div class="container-block">
      <header data-reveal class="mx-auto max-w-[820px]">
        <p class="text-eyebrow text-accent-soft">Из классической традиции</p>
        <h2 class="text-h2-compact mt-4 text-white">Смысловые формулы</h2>
      </header>

      <ol data-reveal-stagger class="mx-auto mt-12 max-w-[820px] max-lg:mt-8">
