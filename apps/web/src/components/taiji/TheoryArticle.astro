---
// Лонгрид «Теоретические основы тайцзицюань» (/taijiquan/theory). Заменяет общую
// заглушку ContentPlaceholder. Тот же editorial-паттерн, что и HistoryArticle:
// колонка чтения ~680px, выносные фигуры/цитаты, аппарат сносок (sup → #src-N),
// плейсхолдеры изображений bg-field с рекомендацией. Заголовок страницы (h1) — в
// InteriorHero, поэтому все разделы здесь — <h2>. Всё на токенах и тип-шкале;
// Cormorant (font-serif) — только editorial-акценты (буквица, врезные цитаты,
// термины глоссария, классические формулы). Reveal — штатный data-reveal/-stagger.
//
// Структурные блоки сверх глав: «Ключевые понятия» — лексикон-глоссарий (полоса
// surface-sunken) и «Смысловые формулы» — тёмная врезка (bg-ink) с классическими
// формулами. Сноски нумерованы по списку «Источники» (1–10); источник 10
// (IEP «Daoist Philosophy») добавлен — в тексте на него ссылаются, в исходном
// списке он был пропущен.

import LongreadFigure from "./LongreadFigure.astro";
import SourcesList from "./SourcesList.astro";
import theoryOpener from "../../assets/taiji/longread/theory-opener.jpg";
import theoryStance from "../../assets/taiji/longread/theory-stance.jpg";
import theoryBagua from "../../assets/taiji/longread/theory-bagua.png";
import theoryManual from "../../assets/taiji/longread/theory-manual.jpg";

// Глоссарий ключевых понятий (рендерится лексиконом, а не таблицей).
const glossary = [
  { term: "Тайцзи", meaning: "Единство, из которого проявляются противоположные, но взаимосвязанные состояния." },
  { term: "Инь-Ян", meaning: "Принцип взаимного перехода: мягкое и твёрдое, движение и покой, пустое и полное." },
  { term: "Пустое и полное", meaning: "Ясное понимание, где находится вес тела, а где есть свобода для движения." },
  { term: "Сун", meaning: "Расслабление без вялости; отпускание лишнего напряжения." },
  { term: "Жоу", meaning: "Мягкость, гибкость, способность не сопротивляться силе напрямую." },
  { term: "И", meaning: "Намерение, направленное внимание, осознанное ведение движения." },
  { term: "Ци", meaning: "Традиционный термин для описания дыхания, жизненной динамики и внутренней связности." },
  { term: "Даньтянь", meaning: "Образ внутреннего центра, чаще всего связанный с нижней частью живота и работой корпуса." },
  { term: "Тринадцать позиций", meaning: "Восемь базовых методов и пять направлений шага." },
];

// Классические смысловые формулы (тёмная врезка).
const maxims = [
  {
    rule: "Движение и покой не противопоставлены.",
    note: "В тайцзицюань движение рождается из собранности, а покой сохраняется внутри движения.",
  },
  {
    rule: "Мягкость не равна слабости.",
    note: "Мягкость означает способность уступить без потери структуры и равновесия.",
  },
  {
    rule: "Пустое и полное нужно различать.",
    note: "Тот, кто не чувствует, где опора, а где свобода, теряет устойчивость и подвижность.",
  },
  {
    rule: "Сила должна проходить через всё тело.",
    note: "Рука не действует отдельно: движение связывает стопы, ноги, корпус, позвоночник и внимание.",
  },
  {
    rule: "Теория проверяется практикой.",
    note: "Классические тексты становятся понятными не сразу, а по мере регулярных занятий.",
  },
];

// Источники. id — якорь для инлайновых сносок. Источник 10 добавлен (см. шапку).
const sources = [
  {
    id: "src-1",
    n: 1,
    title: "UNESCO — «Taijiquan».",
    desc: "Описание тайцзицюань как элемента нематериального культурного наследия и традиционной практики с расслабленными круговыми движениями, дыхательной регуляцией и внутренней собранностью.",
    url: "https://ich.unesco.org/en/RL/taijiquan-00424",
    label: "ich.unesco.org",
  },
  {
    id: "src-2",
    n: 2,
    title: "NCCIH / NIH — «Tai Chi: What You Need To Know».",
    desc: "Официальный обзор тайчи как практики медленных движений, физических позиций, контролируемого дыхания и медитативного состояния.",
    url: "https://www.nccih.nih.gov/health/tai-chi-what-you-need-to-know",
    label: "nccih.nih.gov",
  },
  {
    id: "src-3",
    n: 3,
    title: "Internet Encyclopedia of Philosophy — «Yinyang».",
    desc: "Академическое объяснение инь-ян как одного из центральных понятий китайской философии, связанного с динамическим равновесием и взаимным переходом состояний.",
    url: "https://iep.utm.edu/yinyang/",
    label: "iep.utm.edu",
  },
  {
    id: "src-4",
    n: 4,
    title: "Internet Encyclopedia of Philosophy — «Wuxing».",
    desc: "Объяснение у-син как пяти фаз или процессов, а не статичных «элементов» в западном смысле.",
    url: "https://iep.utm.edu/wuxing/",
    label: "iep.utm.edu",
  },
  {
    id: "src-5",
    n: 5,
    title: "Stanford Encyclopedia of Philosophy — «Metaphysics in Chinese Philosophy».",
    desc: "Контекст понятий тайцзи, инь-ян, у-син и ци в китайской метафизической традиции.",
    url: "https://plato.stanford.edu/entries/chinese-metaphysics/",
    label: "plato.stanford.edu",
  },
  {
    id: "src-6",
    n: 6,
    title: "Barbara Davis — «The Taijiquan Classics: An Annotated Translation».",
    desc: "Аннотированный перевод классических текстов тайцзицюань с комментариями Чэнь Вэймина.",
    url: "https://books.google.com/books/about/The_Taijiquan_Classics.html?id=vOoexFHEKXgC",
    label: "books.google.com",
  },
  {
    id: "src-7",
    n: 7,
    title: "Douglas Wile — «Lost T’ai-chi Classics from the Late Ch’ing Dynasty».",
    desc: "Исследование и перевод позднецинских рукописей по тайцзицюань, важных для понимания классической теории.",
    url: "https://books.google.com/books/about/Lost_T%CA%BBai_chi_Classics_from_the_Late_Ch.html?id=GdU8dJSpQokC",
    label: "books.google.com",
  },
  {
    id: "src-8",
    n: 8,
    title: "Paul Brennan — «The Taiji Classics».",
    desc: "Доступный перевод классических текстов, включая трактат, приписываемый Ван Цзунъюэ, и схему тринадцати позиций.",
    url: "https://brennantranslation.wordpress.com/2013/05/25/the-taiji-classics/",
    label: "brennantranslation.wordpress.com",
  },
  {
    id: "src-9",
    n: 9,
    title: "Chen W. et al., 2023 — «Tai Chi for fall prevention and balance improvement in older adults».",
    desc: "Систематический обзор и метаанализ рандомизированных исследований о влиянии тайчи на баланс и профилактику падений.",
    url: "https://www.frontiersin.org/journals/public-health/articles/10.3389/fpubh.2023.1236050/full",
    label: "frontiersin.org",
  },
  {
    id: "src-10",
    n: 10,
    title: "Internet Encyclopedia of Philosophy — «Daoist Philosophy».",
    desc: "Контекст даосской внутренней алхимии и практик самосовершенствования, к которым восходит язык «внутренней» работы в тайцзицюань.",
    url: "https://iep.utm.edu/daoismdaoist-philosophy/",
    label: "iep.utm.edu",
  },
];
---

<article id="content" class="theory scroll-mt-24 bg-white">
  {/* ── Вступление + главы (белый фон, колонка чтения) ── */}
  <section class="pt-16 pb-4 max-lg:pt-12">
    <div class="container-block">
      {/* Лид-абзац с буквицей */}
      <div data-reveal class="mx-auto max-w-[680px]">
        <span class="block h-[3px] w-14 bg-accent" aria-hidden="true"></span>
        <p
          class="standfirst mt-8 font-serif text-[25px] font-medium leading-[1.5] text-ink max-lg:mt-6 max-lg:text-[20px]"
        >
          Теория тайцзицюань — это не отвлечённая философия, а способ объяснить,
          как должно работать тело в движении.
        </p>
      </div>

      {/* Открывающая широкая фигура */}
      <LongreadFigure
        src={theoryOpener}
        alt="Практик выполняет форму тайцзицюань"
        caption="Инь и ян в движении: теория тайцзицюань — это язык работы тела"
        my="mt-14"
      />

      {/* ── I. Теория как практический язык ── */}
      <div data-reveal class="mx-auto mt-20 max-w-[680px] max-lg:mt-14">
        <p class="text-eyebrow text-accent">Как читать теорию</p>
        <h2 class="text-h2-compact mt-4 text-ink">Теория как практический язык</h2>
        <div class="mt-7 flex flex-col gap-6 max-lg:mt-5">
          <p class="text-body text-ink/80">
            В классических текстах часто используются образы: пустота и
            наполненность, мягкость и твёрдость, движение и покой, центр и
            окружность. Эти слова не нужно понимать буквально или мистически. В
            практике они описывают вполне конкретные вещи: перенос веса,
            устойчивость, расслабление, внимание, дыхание и способность двигаться
            без лишнего напряжения.
          </p>
          <p class="text-body text-ink/80">
            Современное описание тайцзицюань хорошо совпадает с этим практическим
            пониманием. ЮНЕСКО определяет тайцзицюань как традиционную физическую
            практику с расслабленными круговыми движениями, дыхательной
            регуляцией и внутренней собранностью. Национальный центр
            комплементарного и интегративного здоровья США также описывает тайчи
            как практику медленных мягких движений, физических позиций,
            контролируемого дыхания и медитативного состояния
            внимания<sup class="refs"><a href="#src-1">1</a><a href="#src-2">2</a></sup>.
          </p>
          <p class="text-body text-ink/80">
            Поэтому теорию тайцзицюань лучше читать как язык опыта. Она не заменяет
            анатомию, биомеханику или медицину, но помогает ученику понять, что
            именно он должен чувствовать и развивать во время занятий.
          </p>
        </div>
      </div>

      {/* ── II. Тайцзи, инь и ян ── */}
      <div data-reveal class="mx-auto mt-16 max-w-[680px] max-lg:mt-12">
        <p class="text-eyebrow text-accent">Инь и ян</p>
        <h2 class="text-h2-compact mt-4 text-ink">Тайцзи, инь и ян</h2>
        <div class="mt-7 flex flex-col gap-6 max-lg:mt-5">
          <p class="text-body text-ink/80">
            Само слово <em class="term">тайцзи</em> обычно переводят как «Великий
            предел» или «Великая предельность». В китайской философии этот термин
            связан с представлением о едином источнике, из которого проявляются
            взаимодополняющие начала <em class="term">инь</em> и
            <em class="term">ян</em>. Инь и ян — это не «добро и зло» и не две
            враждующие силы. Это способ описать взаимные стороны любого процесса:
            покой и движение, мягкость и активность, тень и свет, накопление и
            раскрытие<sup class="refs"><a href="#src-3">3</a></sup>.
          </p>
          <p class="text-body text-ink/80">
            В тайцзицюань этот принцип становится телесным. Когда вес переходит на
            одну ногу, другая становится свободной. Когда движение раскрывается
            наружу, где-то внутри сохраняется собранность. Когда тело делает шаг
            вперёд, оно не теряет опоры назад. Практикующий учится не застывать в
            одной крайности, а постоянно находить равновесие между
            противоположными состояниями.
          </p>
        </div>
      </div>

      {/* Врезная цитата */}
      <blockquote data-reveal class="mx-auto my-16 max-w-[760px] max-lg:my-12">
        <span class="block h-[3px] w-14 bg-accent" aria-hidden="true"></span>
        <p
          class="mt-7 font-serif text-[32px] font-medium leading-[1.3] text-ink max-lg:mt-5 max-lg:text-[24px]"
        >
          Не напрягаться там, где можно расслабиться; не давить там, где можно
          направить; не терять центр, даже когда всё тело движется.
        </p>
      </blockquote>

      {/* ── III. Пустое и полное ── */}
      <div data-reveal class="mx-auto max-w-[680px]">
        <p class="text-eyebrow text-accent">Вес и опора</p>
        <h2 class="text-h2-compact mt-4 text-ink">Пустое и полное</h2>
        <div class="mt-7 flex flex-col gap-6 max-lg:mt-5">
          <p class="text-body text-ink/80">
            Одно из ключевых понятий тайцзицюань — различение
            <em class="term">пустого</em> и <em class="term">полного</em>. В самом
            простом смысле это означает понимание того, где сейчас находится вес
            тела, а где есть свобода для движения. Например, если человек стоит на
            правой ноге, она становится «полной», а левая — «пустой», то есть
            готовой к шагу, развороту или изменению направления.
          </p>
        </div>
      </div>

      {/* Фигура: пустое/полное — распределение веса */}
      <LongreadFigure
        src={theoryStance}
        alt="Стойка тайцзицюань с ясным распределением веса"
        caption="Пустое и полное: где находится вес тела, а где — свобода для движения"
        aspect="3/4"
        width="max-w-[460px]"
        my="my-12"
      />

      <div data-reveal class="mx-auto max-w-[680px]">
        <div class="flex flex-col gap-6">
          <p class="text-body text-ink/80">
            Это понятие важно не только для равновесия, но и для качества
            движения. Если обе ноги одинаково напряжены и вес распределён неясно,
            тело становится тяжёлым и медленным. Если же практикующий ясно
            чувствует, где опора, а где свобода, движение становится более лёгким,
            точным и устойчивым.
          </p>
          <p class="text-body text-ink/80">
            В боевом контексте пустое и полное помогают не встречать силу
            напрямую. В оздоровительной практике этот же принцип помогает
            безопасно переносить вес, лучше чувствовать стопы, развивать
            координацию и снижать лишнее напряжение.
          </p>
        </div>
      </div>

      {/* ── IV. Мягкость и расслабление ── */}
      <div data-reveal class="mx-auto mt-16 max-w-[680px] max-lg:mt-12">
        <p class="text-eyebrow text-accent">Сун и жоу</p>
        <h2 class="text-h2-compact mt-4 text-ink">Мягкость и расслабление</h2>
        <div class="mt-7 flex flex-col gap-6 max-lg:mt-5">
          <p class="text-body text-ink/80">
            Мягкость в тайцзицюань не означает слабость. Это способность сохранять
            структуру без зажатости. Тело не должно быть вялым, но и не должно
            быть жёстким. Хорошее движение в тайцзицюань похоже на гибкую, но
            цельную систему: суставы свободны, корпус собран, внимание спокойно,
            дыхание не сбивается.
          </p>
          <p class="text-body text-ink/80">
            В китайских текстах для этого часто используют понятия
            <em class="term">сун</em> — отпускание лишнего напряжения, и
            <em class="term">жоу</em> — мягкость, податливость, гибкость.
            Практически это означает, что сила не должна «застревать» в плечах,
            шее, пояснице или коленях. Движение начинается от опоры, проходит через
            корпус и выражается в руках без избыточного мышечного усилия.
          </p>
          <p class="text-body text-ink/80">
            Именно поэтому тайцзицюань не строится на грубой силе. Его задача —
            научить тело действовать согласованно: не отдельной рукой, не отдельной
            ногой, а всей структурой сразу.
          </p>
        </div>
      </div>

      {/* ── V. Ци, намерение и дыхание ── */}
      <div data-reveal class="mx-auto mt-16 max-w-[680px] max-lg:mt-12">
        <p class="text-eyebrow text-accent">Ци, и, дыхание</p>
        <h2 class="text-h2-compact mt-4 text-ink">Ци, намерение и дыхание</h2>
        <div class="mt-7 flex flex-col gap-6 max-lg:mt-5">
          <p class="text-body text-ink/80">
            В традиционном языке тайцзицюань часто встречается понятие
            <em class="term">ци</em>. В китайской философии и медицине ци — широкий
            термин, связанный с дыханием, жизненной динамикой, телесными
            процессами и внутренним состоянием человека. Важно не путать этот
            термин с доказанной анатомической структурой: в современном научном
            смысле ци не измеряется как отдельный физический орган или
            вещество<sup class="refs"><a href="#src-5">5</a></sup>.
          </p>
          <p class="text-body text-ink/80">
            Для обычного читателя удобнее понимать ци как традиционный способ
            говорить о целостном ощущении тела: дыхании, тонусе, тепле, внимании,
            устойчивости и свободном движении. Когда человек расслабляет плечи,
            выравнивает осанку, спокойно дышит и двигается без рывков, он начинает
            лучше чувствовать внутреннюю связность тела. В традиционном языке это
            могли бы описать как «свободное течение ци».
          </p>
          <p class="text-body text-ink/80">
            Не менее важно понятие <em class="term">и</em> — намерение или
            направленное внимание. В тайцзицюань движение не выполняется
            механически. Практикующий сначала осознаёт направление, качество и
            смысл движения, а затем тело следует этому намерению. Поэтому
            тайцзицюань одновременно тренирует и тело, и внимание.
          </p>
        </div>
      </div>

      {/* ── VI. У-син: пять фаз движения ── */}
      <div data-reveal class="mx-auto mt-16 max-w-[680px] max-lg:mt-12">
        <p class="text-eyebrow text-accent">Пять фаз</p>
        <h2 class="text-h2-compact mt-4 text-ink">У-син: пять фаз движения</h2>
        <div class="mt-7 flex flex-col gap-6 max-lg:mt-5">
          <p class="text-body text-ink/80">
            Понятие <em class="term">у-син</em> обычно переводят как «пять
            элементов», но точнее говорить о пяти фазах или пяти процессах. В
            традиционной китайской мысли это дерево, огонь, земля, металл и вода.
            Они описывают не неподвижные вещества, а типы изменений: рост,
            раскрытие, устойчивость, собирание и
            сохранение<sup class="refs"><a href="#src-4">4</a></sup>.
          </p>
        </div>
      </div>

      {/* Фигура: тринадцать позиций — направления */}
      <LongreadFigure
        src={theoryBagua}
        alt="Диаграмма восьми триграмм (багуа)"
        caption="«Тринадцать позиций»: восемь базовых методов рук и пять направлений шага"
        aspect="1/1"
        width="max-w-[520px]"
      />

      <div data-reveal class="mx-auto max-w-[680px]">
        <div class="flex flex-col gap-6">
          <p class="text-body text-ink/80">
            В тайцзицюань эти идеи часто связывают с направлением движения. В
            классической схеме «тринадцати позиций» есть восемь базовых методов
            рук и пять шагов: движение вперёд, назад, влево, вправо и сохранение
            центра. Это не просто геометрия. Такая схема учит человека
            ориентироваться в пространстве, сохранять равновесие и не терять
            внутренний центр при смене
            направления<sup class="refs"><a href="#src-8">8</a></sup>.
          </p>
          <p class="text-body text-ink/80">
            Для начинающего практика здесь важна простая мысль: тайцзицюань
            развивает не отдельные красивые жесты, а способность управлять телом
            во всех направлениях — спокойно, устойчиво и осознанно.
          </p>
        </div>
      </div>

      {/* ── VII. Внутренняя работа ── */}
      <div data-reveal class="mx-auto mt-16 max-w-[680px] max-lg:mt-12">
        <p class="text-eyebrow text-accent">Внутреннее искусство</p>
        <h2 class="text-h2-compact mt-4 text-ink">Внутренняя работа</h2>
        <div class="mt-7 flex flex-col gap-6 max-lg:mt-5">
          <p class="text-body text-ink/80">
            Тайцзицюань часто называют «внутренним» искусством. Это не значит, что
            оно существует отдельно от тела. Напротив, внутренняя работа
            проявляется через вполне видимые качества: ровную осанку, устойчивые
            шаги, мягкую силу, спокойное дыхание, точное внимание и отсутствие
            лишнего напряжения.
          </p>
          <p class="text-body text-ink/80">
            Некоторые школы используют язык даосской внутренней алхимии: говорят о
            <em class="term">даньтяне</em>, внутреннем центре, накоплении энергии,
            соединении дыхания и сознания. Исторически внутренняя алхимия
            относится к даосским практикам самосовершенствования и медитации,
            поэтому такие термины нужно понимать прежде всего как часть культурной
            и практической традиции, а не как медицинские
            утверждения<sup class="refs"><a href="#src-10">10</a></sup>.
          </p>
          <p class="text-body text-ink/80">
            В современном обучении эти образы можно использовать осторожно и
            практично. Например, «двигаться из центра» означает не мистическое
            действие, а умение не дёргать конечностями отдельно, а включать корпус,
            ноги, дыхание и внимание в одно согласованное движение.
          </p>
        </div>
      </div>

      {/* ── VIII. Классические тексты ── */}
      <div data-reveal class="mx-auto mt-16 max-w-[680px] max-lg:mt-12">
        <p class="text-eyebrow text-accent">Трактаты</p>
        <h2 class="text-h2-compact mt-4 text-ink">Классические тексты</h2>
        <div class="mt-7 flex flex-col gap-6 max-lg:mt-5">
          <p class="text-body text-ink/80">
            Теория тайцзицюань передавалась не только через устное обучение, но и
            через короткие трактаты, стихи и наставления. К ним обычно относят
            тексты, связанные с именами Ван Цзунъюэ, У Юйсяна, Ли Июя, Ян Чэнфу,
            Чэнь Вэймина и других мастеров. Эти тексты написаны сжато, образно и
            часто требуют комментариев, потому что один и тот же термин может иметь
            технический, философский и практический смысл
            одновременно<sup class="refs"><a href="#src-6">6</a></sup>.
          </p>
        </div>
      </div>

      {/* Фигура: классический трактат */}
      <LongreadFigure
        src={theoryManual}
        alt="Страница классического трактата по тайцзицюань"
        caption="Классические трактаты — записи практического опыта, а не учебник анатомии"
        aspect="3/4"
        width="max-w-[460px]"
        my="my-12"
      />

      <div data-reveal class="mx-auto max-w-[680px]">
        <div class="flex flex-col gap-6">
          <p class="text-body text-ink/80">
            При этом классические трактаты не следует читать как учебник анатомии
            или современную спортивную методику. Это скорее записи практического
            опыта: как стоять, как двигаться, как не терять центр, как различать
            силу и напряжение, как следовать движению партнёра и как постепенно
            развивать чувствительность.
          </p>
          <p class="text-body text-ink/80">
            Сначала человек запоминает форму. Затем начинает чувствовать вес, ось,
            дыхание и расслабление. И только после этого многие классические
            формулы становятся понятными не как красивые фразы, а как точные
            инструкции к движению.
          </p>
        </div>
      </div>

      {/* Врезная цитата */}
      <blockquote data-reveal class="mx-auto my-16 max-w-[760px] max-lg:my-12">
        <span class="block h-[3px] w-14 bg-accent" aria-hidden="true"></span>
        <p
          class="mt-7 font-serif text-[34px] font-medium leading-[1.25] text-ink max-lg:mt-5 max-lg:text-[26px]"
        >
          Теория тайцзицюань раскрывается через практику.
        </p>
      </blockquote>

      {/* ── IX. Современное научное понимание ── */}
      <div data-reveal class="mx-auto max-w-[680px]">
        <p class="text-eyebrow text-accent">Доказательная база</p>
        <h2 class="text-h2-compact mt-4 text-ink">Современное научное понимание</h2>
        <div class="mt-7 flex flex-col gap-6 max-lg:mt-5">
          <p class="text-body text-ink/80">
            Современная наука не подтверждает философские категории вроде инь-ян
            или ци как физические законы. Но исследования подтверждают
            практические эффекты самого занятия тайцзицюань: оно связано с
            тренировкой равновесия, координации, контроля позы, переноса веса и
            внимания. В систематическом обзоре 2023 года по рандомизированным
            исследованиям тайчи показало эффективность для улучшения баланса и
            снижения риска падений у пожилых
            людей<sup class="refs"><a href="#src-9">9</a></sup>.
          </p>
          <p class="text-body text-ink/80">
            Это позволяет читать традиционную теорию в двух слоях. Первый слой —
            культурный: язык китайской философии, классических текстов и образов.
            Второй слой — практический: работа с телом, дыханием, вниманием и
            устойчивостью. Для современного человека особенно важно соединять эти
            два уровня аккуратно: уважать традицию, но не выдавать символический
            язык за медицинское доказательство.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ── Ключевые понятия (лексикон на полосе surface-sunken) ── */}
  <section class="mt-10 bg-surface-sunken py-24 max-lg:mt-6 max-lg:py-16">
