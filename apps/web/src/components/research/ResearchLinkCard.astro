---
// Карточка-ссылка раздела «Исследования» (/research). Редизайн под editorial-luxury:
// крупный serif-заголовок (Cormorant/font-serif), много воздуха (p-10), парящая
// карточка на мягкой ink-тинтованной тени (shadow-card), nested круглая кнопка-
// стрелка («кнопка-в-кнопке») справа. Hover — лифт + углубление тени + смещение
// стрелки и заливка акцентом, всё на кастомном cubic-bezier (без linear/ease).
// Вся карточка — внешняя ссылка, открывается в новом окне. Острые углы и токены —
// в рамках дизайн-системы сайта. data-reveal-item — staggered-появление (smooth.ts).
import { EXTERNAL_ARROW_PATH } from "../../lib/icons";

interface Props {
  kind: string; // «Источник» / «Публикация» — мета-метка
  year?: string; // год издания (у первоисточников нет)
  title: string;
  desc: string;
  label: string; // домен (видимый ориентир ссылки)
  url: string;
}
const { kind, year, title, desc, label, url } = Astro.props;
const meta = year ? `${kind} · ${year}` : kind;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  data-reveal-item
  class="group grid grid-cols-[1fr_auto] items-center gap-12 bg-white p-10 ring-1 ring-ink/[0.08] transition-[transform,box-shadow] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-1 hover:ring-ink/[0.14] active:translate-y-0 max-lg:grid-cols-1 max-lg:gap-7 max-lg:p-7"
>
  <div class="max-w-[760px]">
    <span class="text-eyebrow text-accent">{meta}</span>
    <h3
      class="mt-5 font-display text-2xl font-semibold leading-[1.2] text-ink max-lg:mt-3 max-lg:text-[20px]"
    >
      {title}
    </h3>
    <p class="mt-5 text-body text-ink/65 max-lg:mt-3">{desc}</p>
    <span
      class="mt-8 inline-flex items-center font-display text-sm font-semibold tracking-wide text-ink/40 transition-colors duration-500 group-hover:text-accent max-lg:mt-6"
    >
      {label}
    </span>
  </div>

  {/* Nested круглая кнопка-стрелка: «кнопка-в-кнопке», заливается акцентом на hover */}
  <span
    aria-hidden="true"
    class="grid h-16 w-16 shrink-0 place-items-center rounded-[2px] bg-accent-soft text-accent transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:-translate-y-1 group-hover:translate-x-1 group-hover:bg-accent group-hover:text-white max-lg:h-12 max-lg:w-12 max-lg:justify-self-start"
  >
    <svg
      viewBox="0 0 24 24"
      class="h-5 w-5 max-lg:h-[18px] max-lg:w-[18px]"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d={EXTERNAL_ARROW_PATH}></path>
    </svg>
  </span>
</a>
