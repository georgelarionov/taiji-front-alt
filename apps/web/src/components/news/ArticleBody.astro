---
// Тело статьи (rich-text) — рендер типизированных блоков из датасета (см. data/news
// → Block). Каждый блок отображается на тип-шкале проекта:
//   • p          → абзац text-body (16px); lead-абзац — font-medium, остальные ink/80;
//   • h2         → подзаголовок text-h2-compact (32/26);
//   • image      → <figure> с оптимизированным <Image> (w-full) + подпись (caption);
//   • quote      → font-serif, border-l accent;
//   • video      → встроенный <iframe> 16:9 (pointer-events:auto — обходит глобальный
//                  .lenis-smooth iframe{pointer-events:none}, иначе плеер не кликается).
// Заголовки внутри тела — <h2> (единственный <h1> — заголовок статьи в ArticleIntro).
import { Image } from "astro:assets";
import type { Block } from "../../data/news";

interface Props {
  body: Block[];
}
const { body } = Astro.props;
---

<div class="article-body flex flex-col gap-6 text-ink">
  {
    body.map((block) => {
      if (block.type === "p") {
        return (
          <p class={block.lead ? "text-body font-medium" : "text-body text-ink/80"}>
            {block.text}
          </p>
        );
      }
      if (block.type === "h2") {
        return <h2 class="text-h2-compact mt-4 text-ink">{block.text}</h2>;
      }
      if (block.type === "image") {
        return (
          <figure class="my-2 flex flex-col gap-3">
            <Image
              src={block.src}
              alt={block.alt}
              widths={[400, 809, 1218]}
              sizes="(max-width: 1024px) 100vw, 809px"
              class="h-auto w-full bg-field"
            />
            {block.caption && (
              <figcaption class="text-caption text-ink/55">{block.caption}</figcaption>
            )}
          </figure>
        );
      }
      if (block.type === "quote") {
        return (
          <blockquote class="my-2 border-l-2 border-accent pl-6 font-serif text-2xl font-medium italic leading-snug text-ink max-lg:pl-4 max-lg:text-[22px]">
            {block.text}
          </blockquote>
        );
      }
      if (block.type === "video") {
        return (
          <div class="my-2 aspect-video w-full overflow-hidden bg-ink">
            <iframe
              src={block.embed}
              title={block.title ?? "Видео"}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              class="h-full w-full border-0"
              style="pointer-events:auto"
            />
          </div>
        );
      }
      return null;
    })
  }
</div>
