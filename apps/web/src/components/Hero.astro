---
// 1-block (hero) — слайдер. Тонкая обвязка вокруг острова HeroSlider:
// импортирует ассеты (Vite-фингерпринт), формирует массив слайдов и рендерит
// остров (client:load — не client:visible, см. гайдлайн по слайдерам).
// Статичную шапку и нижнюю плашку передаём в остров через слоты header/footer —
// так они остаются нулевым JS (React их не «владеет», только размещает).
// Фон-видео: WebM (VP9) для Chrome/Firefox + MP4 фолбэк для Safari; постер —
// hero-bg.webp (первый кадр до загрузки видео). Импортируются как URL'ы.
import { getImage } from "astro:assets";
import HeroSlider, { type HeroSlide } from "./HeroSlider";
import Header from "./Header.astro";
import heroVideoWebm from "../assets/hero/hero-video.webm";
import heroVideoMp4 from "../assets/hero/hero-video.mp4";
// Отдельное видео под мобилу (<1024px) — грузится вместо тяжёлого десктопного.
// Сейчас это плейсхолдер (копия десктопного): заменить файлы hero-video-mobile.*
// на реальное мобильное видео — код менять не нужно.
import heroVideoMobileWebm from "../assets/hero/hero-video-mobile.webm";
import heroVideoMobileMp4 from "../assets/hero/hero-video-mobile.mp4";
import heroBg from "../assets/hero/hero-bg.webp";
// Статичный фон слайда 2 — png-исходник, пережимаем в webp (desktop+mobile).
import slide2Img from "../assets/hero/slide-2.png";
// Эмблема ИКСА РАН для нижней плашки — отдаём как есть (SVG ?url).
import ranEmblem from "../assets/hero/iksa-ran-logo-new.svg?url";

// Адаптивный постер: исходник hero-bg.webp — 4K (3840×2160). На десктопе хватает
// 2560w, на мобиле (<1024px, под тёмным скримом) — 1080w. getImage пережимает
// webp под нужную ширину (оба меньше исходных 3840 → апскейла нет). Остров
// HeroSlider выбирает mobile.poster по matchMedia, поэтому мобиле уходит лёгкий 1080.
const posterDesktop = await getImage({ src: heroBg, width: 2560, format: "webp" });
const posterMobile = await getImage({ src: heroBg, width: 1080, format: "webp" });

// Фон слайда 2 — те же ширины, что у постера (desktop 2560 / mobile 1080), webp.
const slide2Desktop = await getImage({ src: slide2Img, width: 2560, format: "webp" });
const slide2Mobile = await getImage({ src: slide2Img, width: 1080, format: "webp" });

// Слайд 1 — видеофон, CTA ведёт на /taijiquan.
const slide1: HeroSlide = {
  eyebrow: "Что такое тайцзицюань?",
  title: "Китайское внутреннее боевое искусство",
  subtitle: "В котором сила рождается из спокойствия, а движение из внимания.",
  ctaText: "Узнать больше",
  ctaHref: "/taijiquan",
  bg: {
    type: "video",
    webm: heroVideoWebm,
    mp4: heroVideoMp4,
    poster: posterDesktop.src,
    // Мобильный набор (<1024px) — webm+mp4 вместе («оба или ничего», см. тип
    // HeroSlide). Постер — отдельный лёгкий 1080w.
    mobile: {
      webm: heroVideoMobileWebm,
      mp4: heroVideoMobileMp4,
      poster: posterMobile.src,
    },
  },
};

// Слайд 2 — статичный фон (без надзаголовка), CTA ведёт на /taijiquan/practice.
const slide2: HeroSlide = {
  title: "Практика тайцзицюань",
  subtitle: "Форма, внимание, дыхание и работа с телом",
  ctaText: "Узнать больше",
  ctaHref: "/taijiquan/practice",
  bg: {
    type: "image",
    url: slide2Desktop.src,
    mobile: slide2Mobile.src,
  },
};

const slides: HeroSlide[] = [slide2, slide1];
---

<HeroSlider slides={slides} client:load>
  {/* ───────── Шапка (статичная, нулевой JS) — единый Header.astro ───────── */}
  <Header slot="header" variant="overlay" />

  {/* ───────── Нижняя плашка (статичная, нулевой JS) ───────── */}
  <div
    slot="footer"
    class="gutter-x flex items-center justify-between gap-10 max-lg:justify-center max-lg:gap-0 max-lg:pt-4 max-lg:pb-4"
  >
    <div class="flex flex-col gap-1.5 py-[14px] max-lg:hidden">
      <p class="font-display text-[12px] font-bold text-white/75">
        МИССИЯ ОБЩЕСТВА:
      </p>
      <p class="font-display text-[16px] font-semibold">
        Исследование, сохранение и развитие традиционного тайцзицюань в России
      </p>
    </div>
    <div class="flex items-center gap-11">
      <span class="h-[92px] w-px bg-white/25 max-lg:hidden"></span>
      <div class="flex items-center gap-[18px] py-[14px] max-lg:gap-2">
        <img
          src={ranEmblem}
          width={64}
          height={64}
          alt="Эмблема Института Китая и современной Азии РАН"
          class="h-16 w-16 shrink-0 object-contain max-lg:hidden"
        />
        <p
          class="font-display text-sm font-semibold max-lg:text-center max-lg:text-[11px] max-lg:leading-[1.3] max-lg:opacity-85"
        >
          При академической поддержке<br />Института Китая и современной Азии РАН
        </p>
      </div>
    </div>
  </div>
</HeroSlider>

<style>
  /* Слоты, переданные в React-остров, оборачиваются интеграцией в
     <astro-slot>/<astro-static-slot> (по умолчанию display:inline) — это сломало
     бы flex-колонку hero. display:contents убирает обёртку из раскладки: шапка и
     нижняя плашка становятся прямыми flex-детьми, как до выноса в остров. */
  :global(astro-slot),
  :global(astro-static-slot) {
    display: contents;
  }

  /* Вступительная анимация hero-текста — staggered fade-up. Только при JS (html.js)
     и без reduced-motion. Селекторы :global, т.к. [data-rise] теперь рендерит
     React-остров. key={index} в острове ремонтирует текст → анимация
     переигрывается на каждой смене слайда. Без JS / при reduced-motion — виден сразу. */
  /* Текст hero скрыт (только при включённом JS), пока остров не получит reveal —
     он добавляет класс .hero-revealed обёртке текста на УХОДЕ лоудера-сплэша
     (событие taiji:loader-done) или сразу, если лоудера нет. То есть «задержку»
     задаёт реальный уход лоудера, а не магическое число. Тогда ступени поднимаются
     волной: eyebrow → заголовок → подзаголовок → кнопка. Длинная длительность +
     мягкая ease-out = «очень плавно». При смене слайдов обёртка ремонтируется
     (key=index) уже с .hero-revealed → подъём переигрывается сразу.
     Без JS текст виден сразу; при reduced-motion анимация выключена (виден сразу). */
  :global(html.js [data-rise]) {
    opacity: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    :global(html.js .hero-revealed [data-rise]) {
      animation: hero-rise 1.6s var(--ease-smooth) both;
    }
    :global(html.js .hero-revealed [data-rise="1"]) {
      animation-delay: 0.5s;
    }
    :global(html.js .hero-revealed [data-rise="2"]) {
      animation-delay: 0.68s;
    }
    :global(html.js .hero-revealed [data-rise="3"]) {
      animation-delay: 0.86s;
    }
    :global(html.js .hero-revealed [data-rise="4"]) {
      animation-delay: 1.04s;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(html.js [data-rise]) {
      opacity: 1;
    }
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
